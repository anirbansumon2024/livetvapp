<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LiveTV" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/bg_surface</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
    </style>

    <style name="Theme.LiveTV.TV" parent="Theme.Leanback">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.LiveTV.Player" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>
</resources>