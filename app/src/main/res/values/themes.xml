<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.LiveTV" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.LiveTV.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.LiveTV.Splash" parent="Theme.LiveTV.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.LiveTV.Player" parent="Theme.LiveTV.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowKeepScreenOn">true</item>
    </style>

    <style name="Theme.LiveTV.TV" parent="Theme.Leanback">
        <item name="colorPrimary">@color/accent_color</item>
    </style>

</resources>
